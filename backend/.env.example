# ── Serveur ──────────────────────────────────────────────────────────────
PORT=8080
ENV=development          # development | production

# ── Sécurité JWT ─────────────────────────────────────────────────────────
# Générer et ajouter avec :
#   echo "JWT_SECRET=$(openssl rand -hex 64)" >> .env
JWT_ACCESS_TTL=15m       # Durée du token d'accès
JWT_REFRESH_TTL=7d       # Durée du refresh token

# ── Base de données ───────────────────────────────────────────────────────
# Chemin absolu ou relatif vers le fichier SQLite
DB_PATH=./data/cooking-home.db

# ── CORS ──────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Rate limiting ─────────────────────────────────────────────────────────
# Requêtes par seconde par IP (token bucket)
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
