# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Home Cooking (docker-compose)
# Copier en .env et remplir les valeurs OBLIGATOIRES avant de démarrer.
# Ce fichier NE doit PAS être commité avec de vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# ── OBLIGATOIRE ───────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# ── Optionnel (valeurs par défaut définies dans docker-compose.yml) ───────────
# Port HTTPS exposé du frontend sur l'hôte (défaut : 3443)
FRONTEND_PORT=3443
# Port HTTP (redirige vers HTTPS, défaut : 3080)
FRONTEND_HTTP_PORT=3080
