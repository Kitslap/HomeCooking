# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Cooking Home (docker-compose)
# Copier en .env et remplir les valeurs OBLIGATOIRES avant de démarrer.
# Ce fichier NE doit PAS être commité avec de vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# ── OBLIGATOIRE ───────────────────────────────────────────────────────────────
# Générer et ajouter avec :
#   echo "JWT_SECRET=$(openssl rand -hex 64)" >> .env

# ── Optionnel (valeurs par défaut définies dans docker-compose.yml) ───────────
# Port exposé du frontend sur l'hôte (défaut : 3000)
FRONTEND_PORT=3000
